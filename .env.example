# Copy to .env for local overrides.

OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=openlens_multimodal
OPENSEARCH_TIMEOUT_S=30

OPENLENS_DOCS=data/processed/open_corpus.jsonl
OPENLENS_EMBEDDED_DOCS=data/processed/open_corpus_embedded.jsonl
OPENLENS_VECTOR_DIM=384
OPENLENS_USER_AGENT=openlens-opensearch-demo/0.1

# Retrieval model provider.
# feature-hash is lightweight and good for local 100k smoke builds.
# qwen uses Qwen3-VL-Embedding / compatible Qwen3.5 local models.
OPENLENS_EMBEDDING_BACKEND=feature-hash
OPENLENS_QWEN_MODEL=qwen8b
OPENLENS_QWEN_BATCH_SIZE=1
OPENLENS_QWEN_MAX_FRAMES=32
OPENLENS_QWEN_FPS=1.0
OPENLENS_REQUIRE_OPENSEARCH=1
